{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/flows/layout,_N_T_/dashboard/flows/page,_N_T_/dashboard/flows"
  },
  "segmentPaths": [
